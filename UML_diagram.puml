@startuml UML_diagram
' pred-fab-mock architecture: concrete implementations against the pred-fab framework
' Generate PNG: plantuml -tpng UML_diagram.puml

!define CONCRETE_CLASS class

skinparam linetype ortho
skinparam ranksep 60
skinparam nodesep 40
skinparam packagePadding 10

' === AGENT ===
CONCRETE_CLASS PfabAgent {
    + baseline_step()
    + exploration_step()
    + inference_step()
    + adaptation_step()
    + evaluate()
    + train()
}

' === PRED-FAB ORCHESTRATION SYSTEMS ===
CONCRETE_CLASS FeatureSystem {
    + run_feature_extraction()
}

CONCRETE_CLASS EvaluationSystem {
    + run_evaluation()
}

CONCRETE_CLASS PredictionSystem {
    + train()
    + predict_for_calibration()
    + uncertainty()
}

CONCRETE_CLASS CalibrationSystem {
    + run_baseline()
    + run_calibration()
    + configure_step_parameter()
}

' === MOCK: SENSORS ===
CONCRETE_CLASS FabricationSystem #ADD8E655 {
    + run_experiment()
    + run_layer()
}

CONCRETE_CLASS CameraSystem #ADD8E655 {
    + run_layer()
    + get_segment_data()
}

CONCRETE_CLASS EnergySensor #ADD8E655 {
    + run_layer()
    + get_segment_energy()
}

' === MOCK: FEATURE MODELS ===
CONCRETE_CLASS PrintingFeatureModel #90EE9055 {
    + outputs: [layer_width, path_deviation]
    + _load_data()
    + _compute_feature_logic()
}

CONCRETE_CLASS EnergyFeatureModel #90EE9055 {
    + outputs: [energy_per_segment]
    + _load_data()
    + _compute_feature_logic()
}

' === MOCK: EVALUATION MODELS ===
CONCRETE_CLASS PathAccuracyModel #eeb6ff55 {
    + input_feature: path_deviation
    + output_performance: path_accuracy
}

CONCRETE_CLASS EnergyConsumptionModel #eeb6ff55 {
    + input_feature: energy_per_segment
    + output_performance: energy_efficiency
}

' === MOCK: PREDICTION MODEL ===
CONCRETE_CLASS PrintingPredictionModel #FFFFE055 {
    + model: MultiOutputRegressor(RandomForest)
    + outputs: [path_deviation, energy_per_segment]
    + train()
    + forward_pass()
    + encode()
}

' === SCHEMA ===
CONCRETE_CLASS DatasetSchema {
    + parameters
    + features
    + performance_attrs
}

' === LAYOUT ===
PfabAgent -[hidden]down- FeatureSystem
PfabAgent -[hidden]down- EvaluationSystem
PfabAgent -[hidden]down- PredictionSystem
PfabAgent -[hidden]down- CalibrationSystem
FeatureSystem -[hidden]right- EvaluationSystem
EvaluationSystem -[hidden]right- PredictionSystem
PredictionSystem -[hidden]right- CalibrationSystem

FeatureSystem -[hidden]down- PrintingFeatureModel
EvaluationSystem -[hidden]down- PathAccuracyModel
PredictionSystem -[hidden]down- PrintingPredictionModel

PrintingFeatureModel -[hidden]right- EnergyFeatureModel
PathAccuracyModel -[hidden]right- EnergyConsumptionModel

FabricationSystem -[hidden]down- CameraSystem
CameraSystem -[hidden]right- EnergySensor

' === RELATIONSHIPS ===
PfabAgent *-- FeatureSystem
PfabAgent *-- EvaluationSystem
PfabAgent *-- PredictionSystem
PfabAgent *-- CalibrationSystem
PfabAgent o-- DatasetSchema

FeatureSystem o-- PrintingFeatureModel
FeatureSystem o-- EnergyFeatureModel
EvaluationSystem o-- PathAccuracyModel
EvaluationSystem o-- EnergyConsumptionModel
PredictionSystem o-- PrintingPredictionModel

FabricationSystem *-- CameraSystem
FabricationSystem *-- EnergySensor

PrintingFeatureModel --> CameraSystem : get_segment_data()
EnergyFeatureModel --> EnergySensor : get_segment_energy()

@enduml
